<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:BarberManager.ViewModels"
	xmlns:models="using:BarberManager.Models"
             x:Class="BarberManager.Views.AdminPanelView"
             x:DataType="vm:AdminPanelViewModel"
             x:Name="RootControl"
             Background="White">
	<ScrollViewer>
		<Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *" Margin="20">
			<!-- bal panel -->
			<Border Grid.Row="0" Grid.Column="0" Background="#F9F9F9" Padding="20" CornerRadius="10" Margin="10" VerticalAlignment="Top">
				<StackPanel Spacing="10">
					<TextBlock Text="Új Fodrász (Barber) Hozzáadása" FontSize="20" FontWeight="Bold"/>
					<TextBlock Text="{Binding StatusMessage}" Foreground="Red" FontWeight="Bold"/>
					<TextBox Text="{Binding NewName}" Watermark="Név..."/>
					<TextBox Text="{Binding NewEmail}" Watermark="Email cím..."/>
					<TextBox Text="{Binding NewPhone}" Watermark="Telefonszám..."/>
					<Grid>
						<TextBox Text="{Binding NewPassword}" 
                                 Watermark="Jelszó..." 
                                 PasswordChar="*" 
                                 RevealPassword="{Binding IsNewPasswordVisible}" 
                                 Padding="10,6,36,6"/>
						<Button Command="{Binding ToggleNewPasswordVisibilityCommand}"
                                Width="30" Height="30"
                                HorizontalAlignment="Right" VerticalAlignment="Center"
                                Background="Transparent" BorderBrush="{x:Null}" Padding="0" Cursor="Hand">
							<Button.Styles>
								<Style Selector="Button:hover">
									<Setter Property="Background" Value="#22000000"/>
								</Style>
							</Button.Styles>
							<Path Data="{Binding NewPasswordIcon}" Fill="Gray" Stretch="Uniform" Width="20" Height="20" VerticalAlignment="Center"/>
						</Button>
					</Grid>
					<CheckBox IsChecked="{Binding NewIsAdmin}" Content="Rendszergazda (Admin) jogosultság"/>
					<Button Command="{Binding RegisterBarberCommand}" Content="Regisztrálás" Background="Black" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
				</StackPanel>
			</Border>
			<!--jobb panel -->
			<Border Grid.Row="0" Grid.Column="1" Background="#F9F9F9" Padding="20" CornerRadius="10" Margin="10">
				<StackPanel Spacing="10">
					<TextBlock Text="Regisztrált Fodrászok" FontSize="20" FontWeight="Bold"/>
					<ItemsControl ItemsSource="{Binding Barbers}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="models:Barber">
								<Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,8" BoxShadow="0 2 5 0 #11000000">
									<Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
										<StackPanel Spacing="5">
											<!-- nev es admin badge -->
											<StackPanel Orientation="Horizontal" Spacing="10">
												<TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
												<Border Background="#E3F2FD" CornerRadius="4" Padding="6,2" IsVisible="{Binding IsAdmin}">
													<TextBlock Text="Admin" FontSize="10" Foreground="#1976D2" FontWeight="Bold"/>
												</Border>
											</StackPanel>
											<!-- infok -->
											<StackPanel Orientation="Horizontal" Spacing="15">
												<!-- email -->
												<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
													<Path Fill="Gray" Stretch="Uniform" Width="14" Height="14" 
                                                          Data="M23 6V18C23 19.6523 21.6523 21 20 21H4C2.34772 21 1 19.6523 1 18V6C1 4.34315 2.34315 3 4 3H20C21.6569 3 23 4.34315 23 6ZM3.10658 5.55395C3.27196 5.22692 3.61204 5 4 5H20C20.388 5 20.728 5.22692 20.8934 5.55395L12 11.7793L3.10658 5.55395ZM3 7.92066L10.8531 13.4178C11.5417 13.8999 12.4583 13.8999 13.1469 13.4178L21 7.92066V18C21 18.5477 20.5477 19 20 19H4C3.45228 19 3 18.5477 3 18V7.92066Z"/>
													<TextBlock Text="{Binding Email}" FontSize="13" Foreground="Gray"/>
												</StackPanel>
												<!-- phone -->
												<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
													<Path Fill="Gray" Stretch="Uniform" Width="14" Height="14" 
                                                          Data="M2.01192 5.6023C1.83312 3.50023 3.61574 2 5.51161 2H7.88594C9.01915 2 10.0411 2.68182 10.4762 3.72819L11.6459 6.54152C12.0464 7.50457 11.8795 8.61027 11.2126 9.41219L9.96021 10.9182C10.7683 12.1458 11.7862 13.2527 12.9455 14.169L14.5827 12.8019C15.386 12.1311 16.4959 11.9632 17.4616 12.3664L20.2638 13.5364C21.3081 13.9725 21.9881 14.9933 21.9881 16.125C21.9881 16.5154 21.9911 16.906 21.9941 17.3009L21.9941 17.3025C21.997 17.6956 22 18.093 22 18.4913C22 20.387 20.4999 22.1699 18.3975 21.9904C9.85772 21.2613 2.74005 14.1628 2.01192 5.6023ZM5.51161 4C4.56806 4 3.94287 4.70566 4.00472 5.43279C4.65016 13.0211 10.9966 19.3513 18.5676 19.9977C19.2944 20.0597 20 19.4349 20 18.4913C20 18.1013 19.9971 17.7109 19.9941 17.316L19.9941 17.3135C19.9911 16.9206 19.9881 16.5234 19.9881 16.125C19.9881 15.8002 19.7929 15.5072 19.4932 15.382L16.691 14.212C16.4138 14.0963 16.0952 14.1444 15.8646 14.337L13.0326 16.7019L12.4051 16.2603C10.5707 14.9694 8.9987 13.2704 7.86741 11.3384L7.51296 10.733L9.67483 8.13339C9.86626 7.90321 9.91417 7.58583 9.79923 7.30939L8.62943 4.49606C8.50455 4.19571 8.21122 4 7.88594 4H5.51161Z"/>
													<TextBlock Text="{Binding PhoneNum}" FontSize="13" Foreground="Gray"/>
												</StackPanel>
											</StackPanel>
										</StackPanel>
										<Button Grid.Column="1" 
                                                x:CompileBindings="False"
                                                Command="{Binding #RootControl.DataContext.DeleteBarberCommand}" 
                                                CommandParameter="{Binding}" 
                                                Background="#FFF0F0" Foreground="Red" Content="Törlés" Padding="15,8"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>
			<!-- vendegek lista -->
			<Border Grid.Row="1" Grid.ColumnSpan="2" Background="#F9F9F9" Padding="20" CornerRadius="10" Margin="10">
				<StackPanel Spacing="10">
					<TextBlock Text="Regisztrált Vendégek (Felhasználók)" FontSize="20" FontWeight="Bold"/>
					<ItemsControl ItemsControl.ItemsSource="{Binding Users}">
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="models:User">
								<Border Background="White" Padding="15" CornerRadius="8" Margin="0,0,0,8" BoxShadow="0 2 5 0 #11000000">
									<Grid ColumnDefinitions="*, Auto" VerticalAlignment="Center">
										<StackPanel Spacing="5">
											<TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
											<!-- infok -->
											<StackPanel Orientation="Horizontal" Spacing="15">
												<!-- email -->
												<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
													<Path Fill="Gray" Stretch="Uniform" Width="14" Height="14" 
                                                          Data="M23 6V18C23 19.6523 21.6523 21 20 21H4C2.34772 21 1 19.6523 1 18V6C1 4.34315 2.34315 3 4 3H20C21.6569 3 23 4.34315 23 6ZM3.10658 5.55395C3.27196 5.22692 3.61204 5 4 5H20C20.388 5 20.728 5.22692 20.8934 5.55395L12 11.7793L3.10658 5.55395ZM3 7.92066L10.8531 13.4178C11.5417 13.8999 12.4583 13.8999 13.1469 13.4178L21 7.92066V18C21 18.5477 20.5477 19 20 19H4C3.45228 19 3 18.5477 3 18V7.92066Z"/>
													<TextBlock Text="{Binding Email}" FontSize="13" Foreground="Gray"/>
												</StackPanel>
												<!-- phone -->
												<StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
													<Path Fill="Gray" Stretch="Uniform" Width="14" Height="14" 
                                                          Data="M2.01192 5.6023C1.83312 3.50023 3.61574 2 5.51161 2H7.88594C9.01915 2 10.0411 2.68182 10.4762 3.72819L11.6459 6.54152C12.0464 7.50457 11.8795 8.61027 11.2126 9.41219L9.96021 10.9182C10.7683 12.1458 11.7862 13.2527 12.9455 14.169L14.5827 12.8019C15.386 12.1311 16.4959 11.9632 17.4616 12.3664L20.2638 13.5364C21.3081 13.9725 21.9881 14.9933 21.9881 16.125C21.9881 16.5154 21.9911 16.906 21.9941 17.3009L21.9941 17.3025C21.997 17.6956 22 18.093 22 18.4913C22 20.387 20.4999 22.1699 18.3975 21.9904C9.85772 21.2613 2.74005 14.1628 2.01192 5.6023ZM5.51161 4C4.56806 4 3.94287 4.70566 4.00472 5.43279C4.65016 13.0211 10.9966 19.3513 18.5676 19.9977C19.2944 20.0597 20 19.4349 20 18.4913C20 18.1013 19.9971 17.7109 19.9941 17.316L19.9941 17.3135C19.9911 16.9206 19.9881 16.5234 19.9881 16.125C19.9881 15.8002 19.7929 15.5072 19.4932 15.382L16.691 14.212C16.4138 14.0963 16.0952 14.0963 15.8646 14.337L13.0326 16.7019L12.4051 16.2603C10.5707 14.9694 8.9987 13.2704 7.86741 11.3384L7.51296 10.733L9.67483 8.13339C9.86626 7.90321 9.91417 7.58583 9.79923 7.30939L8.62943 4.49606C8.50455 4.19571 8.21122 4 7.88594 4H5.51161Z"/>
													<TextBlock Text="{Binding PhoneNum}" FontSize="13" Foreground="Gray"/>
												</StackPanel>
											</StackPanel>
										</StackPanel>
										<Button Grid.Column="1" 
                                                x:CompileBindings="False"
                                                Command="{Binding #RootControl.DataContext.DeleteUserCommand}" 
                                                CommandParameter="{Binding}" 
                                                Background="#FFF0F0" Foreground="Red" Content="Törlés" Padding="15,8"/>
									</Grid>
								</Border>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</StackPanel>
			</Border>
		</Grid>
	</ScrollViewer>
</UserControl>