<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="BarberManager.Views.LoginView"
			 xmlns:vm="using:BarberManager.ViewModels"
x:DataType="vm:LoginViewModel">
<Grid Background="#222222">

		<Border Background="White"
                Width="380"
                VerticalAlignment="Center"
                CornerRadius="10"
                Padding="30"
                BoxShadow="0 4 10 0 #55000000">

			<StackPanel Spacing="15">
				<!-- Title -->
				<TextBlock Text="{Binding TitleText}"
                           FontSize="24"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

				<!--Uzenet -->
				<TextBlock Text="{Binding ErrorMessage}"
                           Foreground="{Binding MessageColor}" 
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
				
                <!-- Nev -->
				<StackPanel>
					<TextBlock Text="Név" FontWeight="SemiBold" Margin="0,0,0,5"/>
					<TextBox Text="{Binding Name}" Watermark="Írd be a neved..."/>
				</StackPanel>

				<!-- Email  -->
				<StackPanel>
					<TextBlock Text="Email" FontWeight="SemiBold" Margin="0,0,0,5"/>
					<TextBox Text="{Binding Email}" Watermark="Írd be az email címed..."/>
				</StackPanel>

				<!-- Jelszo -->
				<StackPanel>
    <TextBlock Text="Jelszó" FontWeight="SemiBold" Margin="0,0,0,5"/>
    <Grid>
        <TextBox Text="{Binding Password}"
                 PasswordChar="*"
                 RevealPassword="{Binding IsPasswordVisible}"
                 Watermark="Add meg a jelszót..."
                 Padding="10,6,36,6"/>

        <Button Command="{Binding TogglePasswordVisibilityCommand}"
                Width="30" Height="30"
                HorizontalAlignment="Right" VerticalAlignment="Center"
                Background="Transparent"
                BorderBrush="{x:Null}"
                Padding="0"
                Cursor="Hand">
            <Button.Styles>
                <Style Selector="Button:hover">
                    <Setter Property="Background" Value="#22000000"/>
                </Style>
            </Button.Styles>
            <Path Data="{Binding PasswordIcon}"
                  Fill="Gray"
                  Stretch="Uniform"
                  Width="20" Height="20"
                  VerticalAlignment="Center"/>
        </Button>
    </Grid>
</StackPanel>

				<!-- Telefonszam -->
				<StackPanel IsVisible="{Binding IsRegisterMode}">
					<TextBlock Text="Telefonszám" FontWeight="SemiBold" Margin="0,0,0,5"/>
					<TextBox Text="{Binding PhoneNum}" Watermark="Pl.: +36 20 123 4567"/>
				</StackPanel>

				<!-- Submit gomb -->
				<Button Command="{Binding SubmitCommand}"
                        Content="{Binding SubmitButtonText}"
                        HorizontalAlignment="Stretch"
                        HorizontalContentAlignment="Center"
                        Background="Black"
                        Foreground="White"
                        Margin="0,10,0,0"
                        Padding="10"/>

				<!-- Switch gomb -->
				<Button Command="{Binding ToggleModeCommand}"
                        Content="{Binding SwitchModeText}"
                        HorizontalAlignment="Center"
                        Background="Transparent"
                        Foreground="#666666"
                        Cursor="Hand"/>
			</StackPanel>
		</Border>
	</Grid></UserControl>
