18.9905 17.7501L18.5936 17.6164C16.4909 16.9082 14.1791 18.1618 13.7456 20.3562L13.6666 20.7562C13.5855 21.1666 13.2021 21.5 12.7136 21.5H11.2867C10.7983 21.5 10.4149 21.1667 10.3338 20.7562L10.2547 20.356C9.82113 18.1617 7.50931 16.9082 5.40665 17.6165L5.0099 17.7501C4.55092 17.9047 4.06104 17.714 3.83671 17.3373L3.1233 16.1393C2.9058 15.7741 2.97959 15.3073 3.32398 15.0186L3.64185 14.7522C5.36782 13.3056 5.36781 10.6944 3.64185 9.24779L3.32398 8.98137C2.97959 8.69273 2.9058 8.2259 3.1233 7.86067L3.83674 6.66266C4.06106 6.28596 4.55093 6.09528 5.0099 6.24986L5.40676 6.38352C7.50938 7.09166 9.82112 5.83819 10.2547 3.64392L10.3338 3.24375Z" />
            <TextBlock Text="Munkaidő Beállítások" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <!-- Status Message -->
        <TextBlock Grid.Row="1" Text="{Binding StatusMessage}" Foreground="Blue" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <!-- Napok listaja -->
        <ItemsControl Grid.Row="2" ItemsSource="{Binding Days}">
            <ItemsControl.ItemTemplate>
<DataTemplate x:DataType="vm:WorkDayDisplay">
                    <Border Background="#F9F9F9" Padding="15" CornerRadius="8" Margin="0,0,0,5">
                        <Grid ColumnDefinitions="150, *, *">
                            <TextBlock Text="{Binding DayName}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <TextBox Grid.Column="1" Text="{Binding Start}" Margin="5,0"/>
                            <TextBox Grid.Column="2" Text="{Binding End}" Margin="5,0"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- save btn -->
        <Button Grid.Row="3" Command="{Binding SaveAllCommand}" IsEnabled="{Binding !IsLoading}"
                Background="Black" Foreground="White" HorizontalAlignment="Right" Padding="20,10" Margin="0,10,0,0">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Path Fill="White" Stretch="Uniform" Width="18" Height="18" Data="M5 2C4.20435 2 3.44129 2.31607 2.87868 2.87868C2.31607 3.44129 2 4.20435 2 5V19C2 19.7957 2.31607 20.5587 2.87868 21.1213C3.44129 21.6839 4.20435 22 5 22H19C19.7957 22 20.5587 21.6839 21.1213 21.1213C21.6839 20.5587 22 19.7957 22 19V8C22 7.73478 21.8946 7.48043 21.7071 7.29289L16.7071 2.29289C16.5196 2.10536 16.2652 2 16 2H5ZM5 4C4.73478 4 4.48043 4.10536 4.29289 4.29289C4.10536 4.48043 4 4.73478 4 5V19C4 19.2652 4.10536 19.5196 4.29289 19.7071C4.48043 19.8946 4.73478 20 5 20H6V13C6 12.4477 6.44772 12 7 12H17C17.5523 12 18 12.4477 18 13V20H19C19.2652 20 19.5196 19.8946 19.7071 19.7071C19.8946 19.5196 20 19.2652 20 19V8.41421L15.5858 4H9V7H16C16.5523 7 17 7.44772 17 8C17 8.55228 16.5523 9 16 9H8C7.44772 9 7 8.55228 7 8V4H5ZM8 14V20H16V14H8Z"/>
                <TextBlock Text="Beállítások mentése"/>
            </StackPanel>
        </Button>
    </Grid></UserControl>
