<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:BarberManager.ViewModels"
	xmlns:models="using:BarberManager.Models"
             x:Class="BarberManager.Views.LogsViewMobile"
             x:DataType="vm:LogsViewModel"
             Background="White">
	<Grid RowDefinitions="Auto, Auto, *">
		<!-- header -->
		<Border Grid.Row="0" Background="#F7F7F7" Padding="15" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE">
			<StackPanel Spacing="10">
				<TextBlock Text="Rendszernapló" FontSize="24" FontWeight="Bold"/>
				<Grid ColumnDefinitions="*, *">
					<Button Grid.Column="0" Command="{Binding LoadLogsCommand}" Background="Black" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,5,0" Content="Frissítés"/>
					<Button Grid.Column="1" Command="{Binding CleanupLogsCommand}" Background="#FFF0F0" Foreground="Red" BorderBrush="Red" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5,0,0,0" Content="Régi törlése"/>
				</Grid>
			</StackPanel>
		</Border>
		<ProgressBar Grid.Row="1" IsIndeterminate="True" IsVisible="{Binding IsLoading}" Height="2"/>
		<TextBlock Grid.Row="1" Text="{Binding StatusMessage}" IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" Foreground="Blue" Margin="15,5" FontSize="12"/>
		<!-- lista -->
		<ScrollViewer Grid.Row="2" Padding="10">
			<ItemsControl ItemsSource="{Binding Logs}">
				<ItemsControl.ItemTemplate>
					<DataTemplate x:DataType="models:LogEntry">
						<Border Background="#F9F9F9" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="12" Padding="15" Margin="0,0,0,12">
							<StackPanel Spacing="8">
								<!-- idopont es datum -->
								<StackPanel Orientation="Horizontal" Spacing="10">
									<TextBlock Text="{Binding CreatedAt, StringFormat='HH:mm'}" FontSize="18" FontWeight="Bold" Foreground="Black"/>
									<TextBlock Text="{Binding CreatedAt, StringFormat='yyyy.MM.dd.'}" FontSize="14" Foreground="Gray" VerticalAlignment="Center"/>
								</StackPanel>
								<!-- activity -->
								<TextBlock Text="{Binding Activity}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" Foreground="#333333"/>
								<Separator Background="#EEEEEE" Height="1" Margin="0,5"/>
								<StackPanel Spacing="5">
									<!-- barber -->
									<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding Barber, Converter={x:Static ObjectConverters.IsNotNull}}">
										<Path Fill="#1976D2" Stretch="Uniform" Width="14" Height="14" Data="M12 12C14.21 12 16 10.21 16 8C16 5.79 14.21 4 12 4C9.79 4 8 5.79 8 8C8 10.21 9.79 12 12 12ZM12 14C9.33 14 4 15.34 4 18V20H20V18C20 15.34 14.67 14 12 14Z"/>
										<TextBlock Text="{Binding Barber.Name, StringFormat='Fodrász: {0}'}" FontSize="13" Foreground="#1976D2" FontWeight="Medium"/>
									</StackPanel>
									<!-- vendeg -->
									<StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding User, Converter={x:Static ObjectConverters.IsNotNull}}">
										<Path Fill="Gray" Stretch="Uniform" Width="14" Height="14" Data="M12 2C6.48 2 2 6.48 2 12C2 17.52 6.48 22 12 22C17.52 22 22 17.52 22 12C22 6.48 17.52 2 12 2ZM12 20C7.59 20 4 16.41 4 12C4 7.59 7.59 4 12 4C16.41 4 20 7.59 20 12C20 16.41 16.41 20 12 20Z"/>
										<TextBlock Text="{Binding User.Name, StringFormat='Vendég: {0}'}" FontSize="13" Foreground="Gray"/>
									</StackPanel>
								</StackPanel>
							</StackPanel>
						</Border>
					</DataTemplate>
				</ItemsControl.ItemTemplate>
			</ItemsControl>
		</ScrollViewer>
	</Grid>
</UserControl>