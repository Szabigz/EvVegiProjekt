<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="BarberManager.Views.ServicesView"
             xmlns:vm="using:BarberManager.ViewModels"
                xmlns:models="using:BarberManager.Models"
                x:DataType="vm:ServicesViewModel"
                x:Name="Root"
                >
<Grid Margin="20">
        
        <!-- lista nezet (nem szerkesztes) -->
        <Grid RowDefinitions="Auto, Auto, *" IsVisible="{Binding !IsEditing}">
            <TextBlock Grid.Row="0" Text="Szolgáltatások" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>
            
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20" Spacing="10">
                <Button Command="{Binding LoadServicesCommand}" Background="Transparent" ToolTip.Tip="Frissítés">
                    <Path Fill="Black" Stretch="Uniform" Width="25" Height="25" 
                          Data="M12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22C16.3556 22 20.0584 19.2159 21.4307 15.3332C21.6148 14.8125 21.3418 14.2412 20.8211 14.0572C20.3004 13.8731 19.7291 14.146 19.545 14.6668C18.4463 17.7753 15.4817 20 12 20C7.58172 20 4 16.4183 4 12C4 7.58172 7.58172 4 12 4C13.5516 4 14.8662 4.56117 16.1162 5.4406C16.9569 6.03212 17.7348 6.74106 18.5242 7.5H15.5C14.9477 7.5 14.5 7.94772 14.5 8.5C14.5 9.05228 14.9477 9.5 15.5 9.5H21C21.5523 9.5 22 9.05228 22 8.5V3C22 2.44772 21.5523 2 21 2C20.4477 2 20 2.44772 20 3V6.14371C19.1517 5.32583 18.2456 4.49337 17.267 3.80489C15.7949 2.76916 14.0847 2 12 2Z" />
                </Button>
                <Button Command="{Binding ShowAddWindowCommand}" Background="Transparent" ToolTip.Tip="Új hozzáadása">
                    <Path Fill="Black" Stretch="Uniform" Width="25" Height="25" 
                          Data="M12 6C12.5523 6 13 6.44772 13 7V11H17C17.5523 11 18 11.4477 18 12C18 12.5523 17.5523 13 17 13H13V17C13 17.5523 12.5523 18 12 18C11.4477 18 11 17.5523 11 17V13H7C6.44772 13 6 12.5523 6 12C6 11.4477 6.44772 11 7 11H11V7C11 6.44772 11.4477 6 12 6Z M1 12C1 5.92487 5.92487 1 12 1C18.0751 1 23 5.92487 23 12C23 18.0751 18.0751 23 12 23C5.92487 23 1 18.0751 1 12ZM12 3C7.02944 3 3 7.02944 3 12C3 16.9706 7.02944 21 12 21C16.9706 21 21 16.9706 21 12C21 7.02944 16.9706 3 12 3Z" />
                </Button>
                <ProgressBar IsIndeterminate="True" VerticalAlignment="Center" Margin="15,0,0,0" Width="100" IsVisible="{Binding IsLoading}"/>
            </StackPanel>

            <ScrollViewer Grid.Row="2">
                <ItemsControl ItemsSource="{Binding Services}" x:CompileBindings="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:Service">
                            <Border Background="#F9F9F9" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="8" Margin="0,0,0,10" Padding="15">
                                <Grid ColumnDefinitions="*, Auto, Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                        <TextBlock Text="{Binding Price, StringFormat='{}{0} Ft'}" Foreground="#666666"/>
                                    </StackPanel>
                                    
                                    <Button Grid.Column="1" Command="{Binding #Root.DataContext.EditServiceCommand}" 
                                            CommandParameter="{Binding}" Background="Transparent">
                                        <Path Fill="#666666" Stretch="Uniform" Width="18" Height="18" 
                                              Data="M18.4324 4C18.2266 4 18.0227 4.04055 17.8325 4.11933C17.6423 4.19811 17.4695 4.31358 17.3239 4.45914L5.25659 16.5265L4.42524 19.5748L7.47353 18.7434L19.5409 6.67608C19.6864 6.53051 19.8019 6.3577 19.8807 6.16751C19.9595 5.97732 20 5.77348 20 5.56761C20 5.36175 19.9595 5.1579 19.8807 4.96771C19.8019 4.77752 19.6864 4.60471 19.5409 4.45914C19.3953 4.31358 19.2225 4.19811 19.0323 4.11933C18.8421 4.04055 18.6383 4 18.4324 4ZM17.0671 2.27157C17.5 2.09228 17.9639 2 18.4324 2C18.9009 2 19.3648 2.09228 19.7977 2.27157C20.2305 2.45086 20.6238 2.71365 20.9551 3.04493C21.2864 3.37621 21.5492 3.7695 21.7285 4.20235C21.9077 4.63519 22 5.09911 22 5.56761C22 6.03611 21.9077 6.50003 21.7285 6.93288C21.5492 7.36572 21.2864 7.75901 20.9551 8.09029L8.69996 20.3454C8.57691 20.4685 8.42387 20.5573 8.25597 20.6031L3.26314 21.9648C2.91693 22.0592 2.54667 21.9609 2.29292 21.7071C2.03917 21.4534 1.94084 21.0831 2.03526 20.7369L3.39694 15.7441C3.44273 15.5762 3.53154 15.4231 3.6546 15.3001L15.9097 3.04493C16.241 2.71365 16.6343 2.45086 17.0671 2.27157Z" />
                                    </Button>
                                    <Button Grid.Column="2" Command="{Binding #Root.DataContext.DeleteServiceCommand}" 
                                            CommandParameter="{Binding}" Background="Transparent">
                                        <Path Fill="Red" Stretch="Uniform" Width="18" Height="18" 
                                              Data="M7 4C7 2.34315 8.34315 1 10 1H14C15.6569 1 17 2.34315 17 4V5H21C21.5523 5 22 5.44772 22 6C22 6.55228 21.5523 7 21 7H19.9394L19.1153 20.1871C19.0164 21.7682 17.7053 23 16.1211 23H7.8789C6.29471 23 4.98356 21.7682 4.88474 20.1871L4.06055 7H3C2.44772 7 2 6.55228 2 6C2 5.44772 2.44772 5 3 5H7V4ZM9 5H15V4C15 3.44772 14.5523 3 14 3H10C9.44772 3 9 3.44772 9 4V5ZM6.06445 7L6.88085 20.0624C6.91379 20.5894 7.35084 21 7.8789 21H16.1211C16.6492 21 17.0862 20.5894 17.1191 20.0624L17.9355 7H6.06445Z" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Szerktesztes nezet (ha isEditing true) -->
        <Border IsVisible="{Binding IsEditing}" Background="White" Padding="30" CornerRadius="15" BoxShadow="0 4 20 0 #22000000" VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <StackPanel Spacing="10">
                <TextBlock Text="Új szolgáltatás felvétele" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
        
                <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" FontSize="12" HorizontalAlignment="Center" IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

                <TextBlock Text="Szolgáltatás neve" FontWeight="SemiBold"/>
                <TextBox Text="{Binding SelectedService.Name}" Watermark="Pl.: Férfi Hajvágás"/>

                <TextBlock Text="Rövid leírás" FontWeight="SemiBold"/>
                <TextBox Text="{Binding SelectedService.Description}" Watermark="Milyen szolgáltatás ez?" Height="60" TextWrapping="Wrap" AcceptsReturn="True"/>

                <Grid ColumnDefinitions="*, *">
                    <StackPanel Grid.Column="0" Margin="0,0,5,0">
                        <TextBlock Text="Időtartam (perc)" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SelectedService.DurationMinutes}" Watermark="30"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="5,0,0,0">
                        <TextBlock Text="Ár (Ft)" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SelectedService.Price}" Watermark="6000"/>
                    </StackPanel>
                </Grid>

                <Grid ColumnDefinitions="*, *" Margin="0,15,0,0">
                    <Button Grid.Column="0" Command="{Binding CancelEditCommand}" Content="Mégse" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5"/>
                    <Button Grid.Column="1" Command="{Binding SaveServiceCommand}" Background="Black" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Path Fill="White" Stretch="Uniform" Width="14" Height="14" Data="M5 2C4.20435 2 3.44129 2.31607 2.87868 2.87868C2.31607 3.44129 2 4.20435 2 5V19C2 19.7957 2.31607 20.5587 2.87868 21.1213C3.44129 21.6839 4.20435 22 5 22H19C19.7957 22 20.5587 21.6839 21.1213 21.1213C21.6839 20.5587 22 19.7957 22 19V8C22 7.73478 21.8946 7.48043 21.7071 7.29289L16.7071 2.29289C16.5196 2.10536 16.2652 2 16 2H5ZM5 4C4.73478 4 4.48043 4.10536 4.29289 4.29289C4.10536 4.48043 4 4.73478 4 5V19C4 19.2652 4.10536 19.5196 4.29289 19.7071C4.48043 19.8946 4.73478 20 5 20H6V13C6 12.4477 6.44772 12 7 12H17C17.5523 12 18 12.4477 18 13V20H19C19.2652 20 19.5196 19.8946 19.7071 19.7071C19.8946 19.5196 20 19.2652 20 19V8.41421L15.5858 4H9V7H16C16.5523 7 17 7.44772 17 8C17 8.55228 16.5523 9 16 9H8C7.44772 9 7 8.55228 7 8V4H5ZM8 14V20H16V14H8Z"/>
                            <TextBlock Text="Mentés"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>
    </Grid></UserControl>
