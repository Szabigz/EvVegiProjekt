<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:BarberManager.ViewModels"
             x:DataType="vm:AppointmentsViewModel"
             x:Class="BarberManager.Views.AppointmentsView">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="60" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
			<ColumnDefinition Width="*" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition Height="Auto" />
			<RowDefinition Height="*" />
		</Grid.RowDefinitions>

		<!-- header -->
		<Border Grid.Row="0" Grid.ColumnSpan="7" Background="White" Padding="0,10" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE">
			<Grid ColumnDefinitions="60, *, *, *, *, *, *, Auto, Auto">
				<StackPanel Grid.Column="1" HorizontalAlignment="Center">
					<TextBlock Text="Hétfő" FontWeight="Bold" FontSize="14" /><TextBlock Text="{Binding Mon}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
				</StackPanel>
				<StackPanel Grid.Column="2" HorizontalAlignment="Center">
					<TextBlock Text="Kedd" FontWeight="Bold" FontSize="14" /><TextBlock Text="{Binding Tue}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
				</StackPanel>
				<StackPanel Grid.Column="3" HorizontalAlignment="Center">
					<TextBlock Text="Szerda" FontWeight="Bold" FontSize="14" /><TextBlock Text="{Binding Wed}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
				</StackPanel>
				<StackPanel Grid.Column="4" HorizontalAlignment="Center">
					<TextBlock Text="Csütörtök" FontWeight="Bold" FontSize="14" /><TextBlock Text="{Binding Thu}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
				</StackPanel>
				<StackPanel Grid.Column="5" HorizontalAlignment="Center">
					<TextBlock Text="Péntek" FontWeight="Bold" FontSize="14" /><TextBlock Text="{Binding Fri}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
				</StackPanel>
				<StackPanel Grid.Column="6" HorizontalAlignment="Center">
					<TextBlock Text="Szombat" FontWeight="Bold" FontSize="14" /><TextBlock Text="{Binding Sat}" FontSize="11" Foreground="Gray" HorizontalAlignment="Center"/>
				</StackPanel>

				<!-- Balra gomb -->
				<Button Grid.Column="7" Command="{Binding PrevWeekCommand}" Background="Transparent" Padding="10">
					<Path Fill="Black" Stretch="Uniform" Width="14" Height="14" Data="M15.2071 6.29289C15.5976 6.68342 15.5976 7.31658 15.2071 7.70711L10.9142 12L15.2071 16.2929C15.5976 16.6834 15.5976 17.3166 15.2071 17.7071C14.8166 18.0976 14.1834 18.0976 13.7929 17.7071L8.79289 12.7071C8.40237 12.3166 8.40237 11.6834 8.79289 11.2929L13.7929 6.29289C14.1834 5.90237 14.8166 5.90237 15.2071 6.29289Z"/>
				</Button>

				<!-- Jobbra gomb -->
				<Button Grid.Column="8" Command="{Binding NextWeekCommand}" Background="Transparent" Padding="10" Margin="0,0,10,0">
					<Path Fill="Black" Stretch="Uniform" Width="14" Height="14" Data="M8.79289 6.29289C9.18342 5.90237 9.81658 5.90237 10.2071 6.29289L15.2071 11.2929C15.5976 11.6834 15.5976 12.3166 15.2071 12.7071L10.2071 17.7071C9.81658 18.0976 9.18342 18.0976 8.79289 17.7071C8.40237 17.3166 8.40237 16.6834 8.79289 16.2929L13.0858 12L8.79289 7.70711C8.40237 7.31658 8.40237 6.68342 8.79289 6.29289Z"/>
				</Button>
			</Grid>
		</Border>
		
		<!-- Idősávok -->
		<ScrollViewer Grid.Row="1" Grid.ColumnSpan="7" VerticalScrollBarVisibility="Auto">
			<Grid x:Name="CalendarContentGrid">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="60" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /><ColumnDefinition Width="*" />
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" /><RowDefinition Height="Auto" MinHeight="60" />
				</Grid.RowDefinitions>

				<!-- Óra és Félóra feliratok -->
				<TextBlock Grid.Row="0" Grid.Column="0" Text="8:00" Margin="0,0,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="1" Grid.Column="0" Text="8:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="2" Grid.Column="0" Text="9:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="3" Grid.Column="0" Text="9:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="4" Grid.Column="0" Text="10:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="5" Grid.Column="0" Text="10:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="6" Grid.Column="0" Text="11:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="7" Grid.Column="0" Text="11:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="8" Grid.Column="0" Text="12:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="9" Grid.Column="0" Text="12:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="10" Grid.Column="0" Text="13:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="11" Grid.Column="0" Text="13:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="12" Grid.Column="0" Text="14:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="13" Grid.Column="0" Text="14:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="14" Grid.Column="0" Text="15:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="15" Grid.Column="0" Text="15:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="16" Grid.Column="0" Text="16:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="17" Grid.Column="0" Text="16:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="18" Grid.Column="0" Text="17:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="19" Grid.Column="0" Text="17:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="20" Grid.Column="0" Text="18:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="21" Grid.Column="0" Text="18:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="22" Grid.Column="0" Text="19:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="23" Grid.Column="0" Text="19:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="24" Grid.Column="0" Text="20:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>
				<TextBlock Grid.Row="25" Grid.Column="0" Text="20:30" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" Foreground="LightGray" FontSize="11"/>
				<TextBlock Grid.Row="26" Grid.Column="0" Text="21:00" Margin="0,-8,5,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="SemiBold" FontSize="12"/>

				<!-- Rácsvonalak -->
				<Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="9" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="11" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="12" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="13" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="14" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="15" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="16" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="17" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="18" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="19" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="20" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="21" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="22" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="23" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="24" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
				<Border Grid.Row="25" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#FAFAFA"/>
				<Border Grid.Row="26" Grid.Column="1" Grid.ColumnSpan="6" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>

				<Border Grid.Column="0" Grid.RowSpan="27" BorderThickness="0,0,1,0" BorderBrush="#EEEEEE"/>
			</Grid>
		</ScrollViewer>
	</Grid>
</UserControl>