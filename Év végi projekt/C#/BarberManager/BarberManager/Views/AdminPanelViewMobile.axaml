<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:BarberManager.ViewModels"
	xmlns:models="using:BarberManager.Models"
             x:Class="BarberManager.Views.AdminPanelViewMobile"
             x:DataType="vm:AdminPanelViewModel"
             Background="White">
	<Grid>
		<Grid IsVisible="{Binding EditingUser, Converter={x:Static ObjectConverters.IsNull}}">
            <Grid IsVisible="{Binding !IsConfirmingDelete}">
			    <ScrollViewer>
				    <StackPanel Spacing="15" Margin="15">
					    <TextBlock Text="Adminisztráció" FontSize="26" FontWeight="Bold" Margin="0,10"/>
					    <!-- uj fodrasz -->
					    <Border Background="#F9F9F9" Padding="20" CornerRadius="15" BoxShadow="0 2 10 0 #11000000">
						    <StackPanel Spacing="12">
							    <TextBlock Text="Új Fodrász Hozzáadása" FontSize="18" FontWeight="Bold" Foreground="#333333"/>
							    <TextBlock Text="{Binding StatusMessage}" Foreground="Red" FontSize="13" IsVisible="{Binding StatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
							    <TextBox Text="{Binding NewName}" Watermark="Teljes név" Height="45"/>
							    <TextBox Text="{Binding NewEmail}" Watermark="Email cím" Height="45"/>
							    <TextBox Text="{Binding NewPhone}" Watermark="Telefonszám" Height="45"/>
							    <Grid>
								    <TextBox Text="{Binding NewPassword}" Watermark="Jelszó" PasswordChar="*" RevealPassword="{Binding IsNewPasswordVisible}" Height="45" Padding="10,0,45,0" VerticalContentAlignment="Center"/>
								    <Button Command="{Binding ToggleNewPasswordVisibilityCommand}" Width="40" Height="45" HorizontalAlignment="Right" Background="Transparent">
									    <Path Data="{Binding NewPasswordIcon}" Fill="Gray" Stretch="Uniform" Width="20" Height="20"/>
								    </Button>
							    </Grid>
							    <CheckBox IsChecked="{Binding NewIsAdmin}" Content="Admin jogot kap"/>
							    <Button Command="{Binding RegisterBarberCommand}" Content="Fodrász Mentése" Background="Black" Foreground="White" Height="50" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="10" FontWeight="Bold"/>
						    </StackPanel>
					    </Border>
					    <!-- fodraszok listaja -->
					    <TextBlock Text="Regisztrált Fodrászok" FontSize="20" FontWeight="Bold" Margin="0,10,0,5"/>
					    <ItemsControl ItemsSource="{Binding Barbers}">
						    <ItemsControl.ItemTemplate>
							    <DataTemplate x:DataType="models:Barber">
								    <Border Background="White" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" CornerRadius="12" Margin="0,0,0,10" BoxShadow="0 2 5 0 #05000000">
									    <StackPanel Spacing="10">
										    <StackPanel Orientation="Horizontal" Spacing="10">
											    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="18"/>
											    <Border Background="#E3F2FD" CornerRadius="5" Padding="6,2" IsVisible="{Binding IsAdmin}">
												    <TextBlock Text="ADMIN" FontSize="10" Foreground="#1976D2" FontWeight="Bold"/>
											    </Border>
										    </StackPanel>
										    <StackPanel Spacing="5">
											    <StackPanel Orientation="Horizontal" Spacing="8">
												    <Path Fill="Gray" Stretch="Uniform" Width="14" Height="14" Data="M23 6V18C23 19.6523 21.6523 21 20 21H4C2.34772 21 1 19.6523 1 18V6C1 4.34315 2.34315 3 4 3H20C21.6569 3 23 4.34315 23 6ZM3.10658 5.55395C3.27196 5.22692 3.61204 5 4 5H20C20.388 5 20.728 5.22692 20.8934 5.55395L12 11.7793L3.10658 5.55395ZM3 7.92066L10.8531 13.4178C11.5417 13.8999 12.4583 13.8999 13.1469 13.4178L21 7.92066V18C21 18.5477 20.5477 19 20 19H4C3.45228 19 3 18.5477 3 18V7.92066Z"/>
												    <TextBlock Text="{Binding Email}" FontSize="14" Foreground="Gray"/>
											    </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Path Fill="Gray" Stretch="Uniform" Width="14" Height="14" Data="M2.01192 5.6023C1.83312 3.50023 3.61574 2 5.51161 2H7.88594C9.01915 2 10.0411 2.68182 10.4762 3.72819L11.6459 6.54152C12.0464 7.50457 11.8795 8.61027 11.2126 9.41219L9.96021 10.9182C10.7683 12.1458 11.7862 13.2527 12.9455 14.169L14.5827 12.8019C15.386 12.1311 16.4959 11.9632 17.4616 12.3664L20.2638 13.5364C21.3081 13.9725 21.9881 14.9933 21.9881 16.125C21.9881 16.5154 21.9911 16.906 21.9941 17.3009L21.9941 17.3025C21.997 17.6956 22 18.093 22 18.4913C22 20.387 20.4999 22.1699 18.3975 21.9904C9.85772 21.2613 2.74005 14.1628 2.01192 5.6023ZM5.51161 4C4.56806 4 3.94287 4.70566 4.00472 5.43279C4.65016 13.0211 10.9966 19.3513 18.5676 19.9977C19.2944 20.0597 20 19.4349 20 18.4913C20 18.1013 19.9971 17.7109 19.9941 17.316L19.9941 17.3135C19.9911 16.9206 19.9881 16.5234 19.9881 16.125C19.9881 15.8002 19.7929 15.5072 19.4932 15.382L16.691 14.212C16.4138 14.0963 16.0952 14.1444 15.8646 14.337L13.0326 16.7019L12.4051 16.2603C10.5707 14.9694 8.9987 13.2704 7.86741 11.3384L7.51296 10.733L9.67483 8.13339C9.86626 7.90321 9.91417 7.58583 9.79923 7.30939L8.62943 4.49606C8.50455 4.19571 8.21122 4 7.88594 4H5.51161Z"/>
                                                    <TextBlock Text="{Binding PhoneNum}" FontSize="14" Foreground="Gray"/>
                                                </StackPanel>
										    </StackPanel>
										    <Button x:CompileBindings="False" 
                                                    Command="{Binding $parent[UserControl].DataContext.ShowDeleteConfirmationCommand}" 
                                                    CommandParameter="{Binding}" 
                                                    Background="#FFF0F0" Foreground="Red" Content="Fodrász Törlése" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="10" CornerRadius="8"/>
									    </StackPanel>
								    </Border>
							    </DataTemplate>
						    </ItemsControl.ItemTemplate>
					    </ItemsControl>
					    <!-- vendeg lista -->
					    <TextBlock Text="Vendégek (Users)" FontSize="20" FontWeight="Bold" Margin="0,10,0,0"/>
                        
                        <TextBlock Text="{Binding UserStatusMessage}" Foreground="{Binding UserStatusColor}" FontWeight="Bold" Margin="0,0,0,5" IsVisible="{Binding UserStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>

					    <ItemsControl ItemsSource="{Binding Users}">
						    <ItemsControl.ItemTemplate>
							    <DataTemplate x:DataType="models:User">
								    <Border Background="#FDFDFD" BorderBrush="#EEEEEE" BorderThickness="1" Padding="15" CornerRadius="12" Margin="0,0,0,10">
									    <StackPanel Spacing="8">
										    <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="17"/>
										    <StackPanel Orientation="Horizontal" Spacing="8">
											    <Path Fill="Gray" Stretch="Uniform" Width="12" Height="12" Data="M23 6V18C23 19.6523 21.6523 21 20 21H4C2.34772 21 1 19.6523 1 18V6C1 4.34315 2.34315 3 4 3H20C21.6569 3 23 4.34315 23 6ZM3 7.92066L10.8531 13.4178C11.5417 13.8999 12.4583 13.8999 13.1469 13.4178L21 7.92066V18C21 18.5477 20.5477 19 20 19H4C3.45228 19 3 18.5477 3 18V7.92066Z"/>
											    <TextBlock Text="{Binding Email}" FontSize="13" Foreground="Gray"/>
										    </StackPanel>
										    <Grid ColumnDefinitions="*, *" Margin="0,5,0,0">
											    <Button Grid.Column="0" x:CompileBindings="False" 
                                                        Command="{Binding $parent[UserControl].DataContext.StartEditUserCommand}" 
                                                        CommandParameter="{Binding}" 
                                                        Background="#F0F8FF" Foreground="Blue" Content="Szerkesztés" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="8" Margin="0,0,5,0"/>
											    <Button Grid.Column="1" x:CompileBindings="False" 
                                                        Command="{Binding $parent[UserControl].DataContext.ShowDeleteConfirmationCommand}" 
                                                        CommandParameter="{Binding}" 
                                                        Background="#FFF0F0" Foreground="Red" Content="Törlés" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" CornerRadius="8" Margin="5,0,0,0"/>
										    </Grid>
									    </StackPanel>
								    </Border>
							    </DataTemplate>
						    </ItemsControl.ItemTemplate>
					    </ItemsControl>
				    </StackPanel>
			    </ScrollViewer>
            </Grid>
		</Grid>

		<Border IsVisible="{Binding EditingUser, Converter={x:Static ObjectConverters.IsNotNull}}" Background="White" Padding="25" CornerRadius="15" BoxShadow="0 4 20 0 #22000000" VerticalAlignment="Center" Margin="15">
			<StackPanel Spacing="15">
				<TextBlock Text="Vendég szerkesztése" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
				<TextBlock Text="{Binding ModalErrorMessage}" Foreground="Red" FontSize="12" HorizontalAlignment="Center" IsVisible="{Binding ModalErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
				<TextBlock Text="Email cím" FontWeight="SemiBold"/>
				<TextBox Text="{Binding EditUserEmail}" Height="45" VerticalContentAlignment="Center"/>
				<TextBlock Text="Telefonszám" FontWeight="SemiBold"/>
				<TextBox Text="{Binding EditUserPhone}" Watermark="+36201234567" Height="45" VerticalContentAlignment="Center"/>
				<Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
					<Button Grid.Column="0" Command="{Binding CancelEditUserCommand}" Content="Mégse" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="50" Margin="0,0,5,0" CornerRadius="8"/>
					<Button Grid.Column="1" Command="{Binding SaveUserEditCommand}" Background="Black" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="50" Margin="5,0,0,0" Content="Mentés" CornerRadius="8"/>
				</Grid>
			</StackPanel>
		</Border>

		<Border IsVisible="{Binding IsConfirmingDelete}" Background="White" Padding="25" CornerRadius="15" BoxShadow="0 4 20 0 #22000000" VerticalAlignment="Center" Margin="15">
			<StackPanel Spacing="15">
				<TextBlock Text="Biztos vagy benne?" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Foreground="Red"/>
				<TextBlock Text="{Binding DeleteConfirmText}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center" FontSize="15"/>
				<Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
					<Button Grid.Column="0" Command="{Binding CancelDeleteCommand}" Content="Mégse" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="50" Margin="0,0,5,0" CornerRadius="8"/>
					<Button Grid.Column="1" Command="{Binding ExecuteDeleteCommand}" Background="Red" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Height="50" Margin="5,0,0,0" Content="IGEN" CornerRadius="8"/>
				</Grid>
			</StackPanel>
		</Border>
	</Grid>
</UserControl>