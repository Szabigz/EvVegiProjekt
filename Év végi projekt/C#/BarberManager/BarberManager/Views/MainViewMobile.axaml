<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:BarberManager.ViewModels"
             x:Class="BarberManager.Views.MainViewMobile"
             x:DataType="vm:MainViewModel"
             Background="White">
	<Grid RowDefinitions="*, Auto">
		<ContentControl Grid.Row="0" Content="{Binding CurrentPage}" />
		<!-- also resz -->
		<Border Grid.Row="1" IsVisible="{Binding IsLoggedIn}" Background="#F7F7F7" BorderThickness="0,1,0,0" BorderBrush="#EEEEEE" Padding="5">
			<Grid>
				<!-- barber nezet -->
				<Grid ColumnDefinitions="*, *, *, *, *" IsVisible="{Binding !IsAdmin}">
					<Button Grid.Column="0" Command="{Binding NavigateToAppointmentsCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Black" Stretch="Uniform" Width="20" Height="20" Data="M17 2V3H9V2H7V3H5C3.3 3 2 4.3 2 6V20C2 21.7 3.3 23 5 23H19C20.7 23 22 21.7 22 20V6C22 4.3 20.7 3 19 3H17V2H15V3H9V2H7ZM20 11V20C20 20.6 19.4 21 19 21H5C4.6 21 4 20.6 4 20V11H20Z"/>
							<TextBlock Text="Naptár" FontSize="10" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="1" Command="{Binding NavigateToServicesCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Black" Stretch="Uniform" Width="20" Height="20" Data="M9.4 8C9.8 7.4 10 6.7 10 6C10 3.8 8.2 2 6 2C3.8 2 2 3.8 2 6C2 8.2 3.8 10 6 10C6.7 10 7.4 9.8 8 9.4L10.6 12L8 14.6C7.4 14.2 6.7 14 6 14C3.8 14 2 15.8 2 18C2 20.2 3.8 22 6 22C8.2 22 10 20.2 10 18C10 17.3 9.8 16.6 9.4 16L20.7 4.7C21.1 4.3 21.1 3.7 20.7 3.3C20.3 2.9 19.7 2.9 19.3 3.3L12 10.6L9.4 8Z"/>
							<TextBlock Text="Szolg." FontSize="10" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="2" Command="{Binding NavigateToWorkHoursCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Black" Stretch="Uniform" Width="20" Height="20" Data="M12 8C9.8 8 8 9.8 8 12C8 14.2 9.8 16 12 16C14.2 16 16 14.2 16 12C16 9.8 14.2 8 12 8ZM12 2C6.5 2 2 6.5 2 12C2 17.5 6.5 22 12 22C17.5 22 22 17.5 22 12C22 6.5 17.5 2 12 2Z"/>
							<TextBlock Text="Idő" FontSize="10" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="3" Command="{Binding NavigateToProfileCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Black" Stretch="Uniform" Width="20" Height="20" Data="M12 1C9 1 6.5 3.5 6.5 6.5C6.5 9.5 9 12 12 12C15 12 17.5 9.5 17.5 6.5C17.5 3.5 15 1 12 1ZM8 14C4.7 14 2 16.7 2 20V22H22V20C22 16.7 19.3 14 16 14H8Z"/>
							<TextBlock Text="Profil" FontSize="10" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="4" Command="{Binding LogoutCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Red" Stretch="Uniform" Width="20" Height="20" Data="M7 4V2H4C2.9 2 2 2.9 2 4V20C2 21.1 2.9 22 4 22H7V20H4V4H7ZM21.7 12.7L16.7 17.7L15.3 16.3L18.6 13H8V11H18.6L15.3 7.7L16.7 6.3L21.7 11.3C22.1 11.7 22.1 12.3 21.7 12.7Z"/>
							<TextBlock Text="Kilépés" FontSize="10" Foreground="Red" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
				</Grid>
				<!-- admin nezet -->
				<Grid ColumnDefinitions="*, *, *, *" IsVisible="{Binding IsAdmin}">
					<Button Grid.Column="0" Command="{Binding NavigateToAdminPanelCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Black" Stretch="Uniform" Width="20" Height="20" Data="M12 12C14.2 12 16 10.2 16 8C16 5.8 14.2 4 12 4C9.8 4 8 5.8 8 8C8 10.2 9.8 12 12 12ZM12 14C9.3 14 4 15.3 4 18V20H20V18C20 15.3 14.7 14 12 14Z"/>
							<TextBlock Text="Kezelés" FontSize="10" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="1" Command="{Binding NavigateToLogsCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Black" Stretch="Uniform" Width="20" Height="20" Data="M19 3H5C3.9 3 3 3.9 3 5V19C3 20.1 3.9 21 5 21H19C20.1 21 21 20.1 21 19V5C21 3.9 20.1 3 19 3ZM7 7H17V9H7V7ZM7 11H17V13H7V11ZM7 15H14V17H7V15Z"/>
							<TextBlock Text="Napló" FontSize="10" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="2" Command="{Binding NavigateToProfileCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Black" Stretch="Uniform" Width="20" Height="20" Data="M12 1C9 1 6.5 3.5 6.5 6.5C6.5 9.5 9 12 12 12C15 12 17.5 9.5 17.5 6.5C17.5 3.5 15 1 12 1ZM8 14C4.7 14 2 16.7 2 20V22H22V20C22 16.7 19.3 14 16 14H8Z"/>
							<TextBlock Text="Profil" FontSize="10" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
					<Button Grid.Column="3" Command="{Binding LogoutCommand}" Background="Transparent" HorizontalAlignment="Stretch">
						<StackPanel Spacing="2">
							<Path Fill="Red" Stretch="Uniform" Width="20" Height="20" Data="M7 4V2H4C2.9 2 2 2.9 2 4V20C2 21.1 2.9 22 4 22H7V20H4V4H7ZM21.7 12.7L16.7 17.7L15.3 16.3L18.6 13H8V11H18.6L15.3 7.7L16.7 6.3L21.7 11.3C22.1 11.7 22.1 12.3 21.7 12.7Z"/>
							<TextBlock Text="Kilépés" FontSize="10" Foreground="Red" HorizontalAlignment="Center"/>
						</StackPanel>
					</Button>
				</Grid>
			</Grid>
		</Border>
	</Grid>
</UserControl>