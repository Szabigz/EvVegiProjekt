<UserControl
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:vm="using:BarberManager.ViewModels"
	xmlns:models="using:BarberManager.Models"
             x:Class="BarberManager.Views.AppointmentsViewMobile"
             x:DataType="vm:AppointmentsViewModel"
             Background="White">
	<Grid>
		<Grid RowDefinitions="Auto, *">
			<Grid.IsVisible>
				<MultiBinding Converter="{x:Static BoolConverters.And}">
					<Binding Path="!IsAddingAppointment"/>
					<Binding Path="!IsViewingDetails"/>
				</MultiBinding>
			</Grid.IsVisible>
			<!-- header-->
			<Border Grid.Row="0" Background="White" Padding="15,20" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE">
				<Grid ColumnDefinitions="*, Auto">
					<StackPanel VerticalAlignment="Center">
						<TextBlock Text="Mai Foglalások" FontSize="22" FontWeight="Bold" Foreground="Black"/>
						<TextBlock Text="Csak a mai napi időpontok" FontSize="14" Foreground="Gray"/>
					</StackPanel>
					<Button Grid.Column="1" Command="{Binding ShowAddPanelCommand}" Background="Black" CornerRadius="10" Padding="15">
						<Path Fill="White" Stretch="Uniform" Width="24" Height="24" 
							  Data="M12 6V18 M6 12H18" Stroke="White" StrokeThickness="2"/>
					</Button>
				</Grid>
			</Border>
			<!-- naptar -->
			<ScrollViewer Grid.Row="1">
				<Grid x:Name="CalendarContentGrid">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="70" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
						<RowDefinition Height="Auto" MinHeight="80" />
					</Grid.RowDefinitions>
					<!-- Órák -->
					<TextBlock Grid.Row="0" Text="8:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="2" Text="9:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="4" Text="10:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="6" Text="11:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="8" Text="12:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="10" Text="13:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="12" Text="14:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="14" Text="15:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="16" Text="16:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="18" Text="17:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<TextBlock Grid.Row="20" Text="18:00" Margin="0,-10,10,0" HorizontalAlignment="Right" VerticalAlignment="Top" FontWeight="Bold" FontSize="14"/>
					<!-- Rácsvonalak -->
					<Border Grid.Row="1" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="3" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="5" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="7" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="9" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="11" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="13" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="15" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="17" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Row="19" Grid.Column="1" BorderThickness="0,0,0,1" BorderBrush="#EEEEEE"/>
					<Border Grid.Column="0" Grid.RowSpan="21" BorderThickness="0,0,1,0" BorderBrush="#DDDDDD"/>
				</Grid>
			</ScrollViewer>
		</Grid>
		<!-- Részletek ablak -->
		<Border IsVisible="{Binding IsViewingDetails}" Background="White" Padding="25" CornerRadius="20" Margin="20" BoxShadow="0 10 40 0 #55000000" VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxHeight="700">
			<ScrollViewer>
				<StackPanel Spacing="15" Margin="0,0,0,10">
					<Grid ColumnDefinitions="*, Auto, Auto">
						<TextBlock Grid.Column="0" Text="Részletek" FontSize="22" FontWeight="Bold" VerticalAlignment="Center"/>
						<Border Grid.Column="1" Background="#EEEEEE" Padding="10,5" CornerRadius="8" Margin="0,0,10,0" VerticalAlignment="Center">
							<TextBlock Text="{Binding SelectedAppointment.Status}" FontWeight="Bold" Foreground="Gray" FontSize="14"/>
						</Border>
						<Button Grid.Column="2" Command="{Binding CloseDetailsCommand}" Background="#F5F5F5" CornerRadius="20" Padding="8">
							<Path Fill="Black" Stretch="Uniform" Width="16" Height="16" Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12 19 6.41Z"/>
						</Button>
					</Grid>
					<Separator Background="#EEEEEE"/>
					<StackPanel Spacing="5">
						<TextBlock Text="Vendég neve:" FontWeight="Bold" Foreground="Gray" FontSize="14"/>
						<TextBlock Text="{Binding SelectedAppointment.GuestName}" FontSize="22" FontWeight="SemiBold"/>
					</StackPanel>
					<StackPanel Spacing="10">
						<StackPanel Spacing="5">
							<TextBlock Text="Telefonszám:" FontWeight="Bold" Foreground="Gray" FontSize="14"/>
							<TextBlock Text="{Binding SelectedAppointment.GuestPhone}" FontSize="18"/>
						</StackPanel>
						<StackPanel Spacing="5">
							<TextBlock Text="Email cím:" FontWeight="Bold" Foreground="Gray" FontSize="14"/>
							<TextBlock Text="{Binding SelectedAppointment.GuestEmail}" FontSize="18"/>
						</StackPanel>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Szolgáltatás:" FontWeight="Bold" Foreground="Gray" FontSize="14"/>
						<TextBlock Text="{Binding SelectedAppointment.ServiceName}" FontSize="18"/>
						<TextBlock Text="{Binding SelectedAppointment.ServicePrice}" FontSize="16" Foreground="DarkGreen" FontWeight="Bold"/>
					</StackPanel>
					<StackPanel Spacing="5" IsVisible="{Binding SelectedAppointment.HasComment}">
						<TextBlock Text="Vendég megjegyzése:" FontWeight="Bold" Foreground="Gray" FontSize="14"/>
						<Border Background="#F9F9F9" Padding="15" CornerRadius="8" BorderBrush="#EEEEEE" BorderThickness="1">
							<TextBlock Text="{Binding SelectedAppointment.Comment}" FontStyle="Italic" TextWrapping="Wrap" FontSize="16"/>
						</Border>
					</StackPanel>
					<Button Command="{Binding ExecuteActionCommand}" Background="#FFF0F0" BorderBrush="Red" BorderThickness="1" Foreground="Red" FontWeight="Bold" FontSize="16" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="20" Margin="0,15,0,0">
						<TextBlock Text="{Binding ActionButtonText}"/>
					</Button>
				</StackPanel>
			</ScrollViewer>
		</Border>
		<!-- Hozzáadás ablak -->
		<Border IsVisible="{Binding IsAddingAppointment}" Background="White" Padding="20" CornerRadius="20" Margin="15" BoxShadow="0 10 40 0 #55000000" VerticalAlignment="Center" HorizontalAlignment="Stretch" MaxHeight="700">
			<ScrollViewer>
				<StackPanel Spacing="15" Margin="0,0,0,10">
					<TextBlock Text="Új Foglalás" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
					<TextBlock Text="{Binding AddErrorMessage}" Foreground="Red" FontSize="14" HorizontalAlignment="Center" IsVisible="{Binding AddErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
					<StackPanel Spacing="5">
						<TextBlock Text="Vendég kiválasztása" FontWeight="SemiBold" FontSize="16" Foreground="Gray"/>
						<ComboBox ItemsSource="{Binding AllUsers}" SelectedItem="{Binding NewSelectedUser}" HorizontalAlignment="Stretch" Height="45">
							<ComboBox.ItemTemplate>
								<DataTemplate x:DataType="models:User">
									<TextBlock Text="{Binding DisplayName}" FontSize="16"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Szolgáltatás" FontWeight="SemiBold" FontSize="16" Foreground="Gray"/>
						<ComboBox ItemsSource="{Binding AllServices}" SelectedItem="{Binding NewSelectedService}" HorizontalAlignment="Stretch" Height="45">
							<ComboBox.ItemTemplate>
								<DataTemplate x:DataType="models:Service">
									<TextBlock Text="{Binding Name}" FontSize="16"/>
								</DataTemplate>
							</ComboBox.ItemTemplate>
						</ComboBox>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Dátum" FontWeight="SemiBold" FontSize="16" Foreground="Gray"/>
						<DatePicker SelectedDate="{Binding NewDate}" HorizontalAlignment="Stretch" Height="45"/>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Szabad időpontok" FontWeight="SemiBold" FontSize="16" Foreground="Gray"/>
						<ComboBox ItemsSource="{Binding AvailableTimeSlots}" SelectedItem="{Binding NewTime}" HorizontalAlignment="Stretch" Height="45"/>
					</StackPanel>
					<StackPanel Spacing="5">
						<TextBlock Text="Megjegyzés" FontWeight="SemiBold" FontSize="16" Foreground="Gray"/>
						<TextBox Text="{Binding NewComment}" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Watermark="Telefonos foglalás, stb..." FontSize="16"/>
					</StackPanel>
					<Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
						<Button Grid.Column="0" Command="{Binding CloseAddPanelCommand}" Content="Mégse" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5" Padding="15" FontSize="16"/>
						<Button Grid.Column="1" Command="{Binding SaveAppointmentCommand}" Content="Mentés" Background="Black" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="5" Padding="15" FontSize="16" IsEnabled="{Binding !IsSaving}"/>
					</Grid>
				</StackPanel>
			</ScrollViewer>
		</Border>
	</Grid>
</UserControl>